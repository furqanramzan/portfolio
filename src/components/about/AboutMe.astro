---
import type { Src } from '@/components/Image.astro';
import Image from '@/components/Image.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import profile from './profile.jpg';

interface Props {
  page?: 'home' | 'other';
  center?: boolean;
}

const { page, center } = Astro.props;

const classes =
  center === true ? 'items-center text-center' : 'items-start text-left';
const image = profile as unknown as Src;
const isOther = page === 'other';
if (isOther) {
  image.width = 150;
  image.height = 150;
} else {
  image.width = 300;
  image.height = 300;
}
---

<div transition:name="aboutme" class={`flex flex-col gap-7 ${classes}`}>
  <div class={`flex flex-col gap-1  ${classes}`}>
    <Image
      transition:persist={isOther}
      loading="eager"
      class="mb-3 rounded-2xl"
      src={image}
      alt="Muhammad Furqan"
    />
    <p class="text-gray-500 dark:text-gray-400">Hello, I am</p>
    <h1 class="text-5xl font-bold">Muhammad Furqan</h1>
    <p class="my-1 w-11/12 text-sm text-gray-500 sm:w-2/3">
      Full-Stack Developer | TypeScript, Node.js, SvelteKit, Nuxt, Next.js, PHP,
      Laravel, JavaScript, Svelte, Vue.js, React, Tailwind CSS, MySQL, Docker,
      Vercel
    </p>
    <p class="text-2xl leading-10">
      <Fragment
        set:html="With 10 years of experience, transforming your visionary ideas into captivating digital experiences. My diverse skill set ensures innovative solutions and your success."
      />
    </p>
  </div>
  <slot />
  <SocialLinks />
</div>
