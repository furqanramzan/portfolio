---
import type { Props as NavigationButtonsProps } from '@/components/NavigationButtons.astro';
import type { Props as PortfolioProps } from '@/layouts/Portfolio.astro';
import AboutMe from '@/components/about/AboutMe.astro';
import Link from '@/components/Link.astro';
import NavigationButtons from '@/components/NavigationButtons.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import Portfolio from '@/layouts/Portfolio.astro';
import { links, navLinks } from '@/utils/constants';

interface Props extends PortfolioProps {
  navigationLinks?: NavigationButtonsProps;
}
const { navigationLinks, active, ...props } = Astro.props;
---

<Portfolio {...props} active={active}>
  <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
    <div
      class="sticky top-0 h-screen scrollbar-none overflow-y-scroll pt-10 max-lg:hidden"
    >
      <AboutMe page="other">
        <nav class="flex flex-col gap-4" id="desktop_nav">
          {
            navLinks.map((link, index) => (
              <Link
                class={`flex items-center gap-2 text-gray-500 transition-all [&>span]:bg-gray-500 ${
                  links[active] === links[link] &&
                  `text-black! dark:text-white! [&>span]:w-24! [&>span]:bg-black! [&>span]:dark:bg-white!`
                }`}
                href={links[link].href}
              >
                {`0${index + 1}`}
                <span class="h-px w-10 transition-all" />
                {links[link].name}
              </Link>
            ))
          }
        </nav>
      </AboutMe>
    </div>
    <div>
      <main class="flex flex-col gap-14">
        <slot />
        {navigationLinks && <NavigationButtons {...navigationLinks} />}
        <div class="flex justify-center lg:hidden">
          <SocialLinks />
        </div>
      </main>
    </div>
  </div>
</Portfolio>
