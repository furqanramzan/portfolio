{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "nx exec -- astro dev",
    "build": "nx exec -- astro build",
    "preview": "nx exec -- astro preview",
    "typecheck": "nx exec -- astro check && nx exec -- tsc --noEmit",
    "lint": "nx exec -- eslint . --fix",
    "lintcheck": "nx exec -- eslint . --max-warnings 0",
    "format": "nx exec -- prettier --write . --plugin=prettier-plugin-astro --plugin=prettier-plugin-tailwindcss",
    "formatcheck": "nx exec -- prettier --list-different . --plugin=prettier-plugin-astro --plugin=prettier-plugin-tailwindcss",
    "precommit": "pnpm run format && pnpm run lint",
    "precommitcheck": "nx run-many -t=formatcheck,lintcheck,typecheck,build --parallel=4",
    "deploy": "nx exec -- ./deploy.sh",
    "postinstall": "astro sync"
  },
  "dependencies": {
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^7.0.5",
    "astro-compress": "^2.4.1",
    "astro-iconify": "^1.3.1",
    "astro-preload": "^1.1.2",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "flowbite": "^4.0.2",
    "sharp": "^0.35.3",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.2",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/ts-plugin": "^1.10.9",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "nx": "^23.0.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ],
        "cache": true
      }
    }
  }
}
